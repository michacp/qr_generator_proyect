---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
import type { Locale } from '../i18n';

export interface Props {
  title?: string;
  description?: string;
  lang?: Locale;
  canonicalUrl?: string;
  ogImage?: string;
  alternateLangs?: Locale[];
}

const {
  title = 'Generador de Códigos QR Gratis | QR TeamCellMania',
  description = 'Crea códigos QR personalizados con colores, logos y diferentes estilos. Gratis, sin registro y con descarga en alta calidad.',
  lang = 'es',
  canonicalUrl = `https://gqr.teamcellmania.com/${lang}/`,
  ogImage = 'https://gqr.teamcellmania.com/og-image.png',
  alternateLangs = [],
} = Astro.props;

const siteName = 'QR TeamCellMania';
const localeMap: Record<string, string> = { es: 'es_EC', en: 'en_US' };

// Clave de Google Analytics desde .env
const gaId = import.meta.env.PUBLIC_GA_ID;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="generador QR, código QR personalizado, QR con logo, crear QR gratis, QR con colores, QR Ecuador, TeamCellMania" />
    <meta name="author" content="TeamCellMania" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang -->
    {alternateLangs.map(l => (
      <link
        rel="alternate"
        hreflang={l}
        href={`https://gqr.teamcellmania.com/${l}/`}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href="https://gqr.teamcellmania.com/es/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Generador de Códigos QR - TeamCellMania" />
    <meta property="og:locale" content={localeMap[lang] ?? 'es_EC'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@teamcellmania" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": "Generador de Códigos QR - TeamCellMania",
        "url": "https://gqr.teamcellmania.com/",
        "description": "Herramienta gratuita para crear códigos QR personalizados con colores, logos y distintos estilos de puntos.",
        "applicationCategory": "UtilitiesApplication",
        "operatingSystem": "Web",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        "publisher": {
          "@type": "Organization",
          "name": "TeamCellMania",
          "url": "https://teamcellmania.com"
        }
      }
    </script>

    <!-- Iconos y Manifest -->
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#6d28d9" />

    <!-- Performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://gqr.teamcellmania.com" />
  </head>

  <body class="bg-[#0a0a0f] font-body text-slate-200 antialiased min-h-screen">
    <slot />
  </body>
</html>

<!-- Google Analytics -->
{gaId && (
  <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
)}

<script define:vars={{ gaId }}>
  if (gaId) {
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', gaId);
  }
</script>