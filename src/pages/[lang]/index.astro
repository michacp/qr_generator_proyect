---
// src/pages/[lang]/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import QrGenerator from '../../components/QrGenerator';
import { LOCALES, getTranslations } from '../../i18n';
import type { Locale } from '../../i18n';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const lang           = Astro.params.lang as Locale;
const t              = getTranslations(lang);
const alternateLangs = LOCALES.filter((l) => l !== lang);
---

<BaseLayout
  title={t.meta.title}
  description={t.meta.description}
  lang={lang}
  canonicalUrl={`https://gqr.teamcellmania.com/${lang}/`}
  alternateLangs={alternateLangs}
  ogImageAlt={t.meta.og_image_alt}
>
  <QrGenerator client:only="react" t={t} lang={lang} />
</BaseLayout>