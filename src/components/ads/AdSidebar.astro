---
// src/components/ads/AdSidebar.astro
// Molécula: posiciona el banner 300×250 en el sidebar.
// Solo visible en desktop (lg+) — en móvil usa AdBottom.
import AdEffective from './ad-scripts/AdEffective.astro';
---
<aside
  class="hidden lg:flex w-[300px] flex-shrink-0 justify-center"
  aria-label="Publicidad"
>
  <div
    class="w-[300px] rounded-2xl overflow-hidden opacity-80 hover:opacity-100 transition-opacity"
  >
    <AdEffective />
  </div>
</aside>