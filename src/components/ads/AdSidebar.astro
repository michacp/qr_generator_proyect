---
// src/components/ads/AdSidebar.astro
const isProd = import.meta.env.PROD;
---

{isProd && (
  <div
    class="hidden lg:block w-[300px] rounded-2xl overflow-hidden opacity-80 hover:opacity-100 transition-opacity"
    aria-label="Publicidad"
    id="ad-sidebar-container"
  >
  </div>

  <script is:inline>
    (function() {
      var container = document.getElementById('ad-sidebar-container');
      if (!container) return;
      var slot = document.createElement('div');
      slot.id = 'container-4789f06421a59c42cf84a3a90b9559d2';
      container.appendChild(slot);
      var s = document.createElement('script');
      s.async = true;
      s.setAttribute('data-cfasync', 'false');
      s.src = 'https://pl29466491.effectivecpmnetwork.com/4789f06421a59c42cf84a3a90b9559d2/invoke.js';
      container.appendChild(s);
    })();
  </script>
)}